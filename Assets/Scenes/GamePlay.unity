  m_Script: {fileID: 11500000, guid: 1206a6c0a62f9c64e9c73d189e79855a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueManager
  speech:
  - " So you\u2019re looking for a witch, huh? My Name is Agatha Ironwood, but you
    can call me AI!\r\nYou look terribly lonely, that\u2019 right?"
  - " Ive got just the thing for you, a perfect virtual boyfriend. \r\nYa\u2019 interested?
    AH, of course you are!"
  - "Just tell me what you want in a partner.\r\nThen write down your wishes, too
    em into the cauldron and puff! You won\u2019t be lonely anymore.\r\n"
  - "Yes, yes, it\u2019s easy! Visit the 3 stores down the road and select what you
    want in your partner. Then just continue down the path!"
  textSpeed: 0.03
  speechText: {fileID: 1582867414}
  textBox: {fileID: 307291239}
  dialoguePanel: {fileID: 2126793925}
  playerMovement: {fileID: 1083380082}
  EnterAction:
