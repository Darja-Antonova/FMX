--- !u!114 &307291238
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 307291236}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1206a6c0a62f9c64e9c73d189e79855a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueManager
  speech:
  - "So you\u2019re looking for a witch, huh? My Name is Agatha Ironwood, but you
    can call me AI!\r\nYou look terribly lonely, that\u2019s right?"
  - Yes.
  - "Yes, extremely lonely, so lonely\u2026"
  - "I've got just the thing for you, a perfect virtual boyfriend. \r\nYa' interested?
    Ah, of course you are!"
  - "Just choose what you want in a partner.\r\nThen write down your wishes, throw
    'em into the cauldron and puff! You won\u2019t be lonely anymore.\r\n"
  - 'Wishes? Cauldron?

'
  - "Yes, yes, it\u2019s easy! Visit the 3 stores down the road and select what you
    want in your partner. Then just continue down the path till you see a bubbling
    pot! "
  textSpeed: 0.03
  speechText: {fileID: 1582867414}
  textBox: {fileID: 307291239}
  dialoguePanel: {fileID: 2126793925}
  dialogueClips:
  - {fileID: 8300000, guid: 24d3ad8ec2219514b993586609418456, type: 3}
